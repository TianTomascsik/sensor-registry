# --- Django-Kernkonfiguration ---
# Umgebung: "dev" oder "prod" (steuert das geladene Settings-Modul via manage.py/wsgi/asgi)
DJANGO_ENV=dev

# Geheimer Schlüssel. In Produktion zwingend mit einem zufälligen Wert überschreiben:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=bitte-fuer-produktion-ersetzen

# Kommagetrennte Liste erlaubter Hostnamen (Produktion), z. B. "app.example.com,www.example.com"
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Kommagetrennte Liste vertrauenswürdiger Origins für CSRF (Produktion, inkl. Schema),
# z. B. "https://app.example.com"
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Datenbank (PostgreSQL) ---
# Vollständige Verbindungs-URL. Für die per docker compose bereitgestellte Dev-DB passt der Standard.
DATABASE_URL=postgres://papa:papa@127.0.0.1:5432/papa

# --- Medien-Auslieferung ---
# "django": Django liefert geschützte Dateien direkt (Entwicklung).
# "accel":  Django delegiert an Nginx via X-Accel-Redirect (Produktion).
MEDIA_SERVE_BACKEND=django
# Interne Nginx-Location, an die X-Accel-Redirect delegiert (nur bei MEDIA_SERVE_BACKEND=accel).
MEDIA_ACCEL_LOCATION=/_protected_media/

# --- Karte (Tile-Quelle) ---
# Standard ist OpenStreetMap – nur für Entwicklung/leichte Nutzung. Für Produktion einen
# eigenen Tile-Server oder einen Provider mit API-Key eintragen (OSMs Volunteer-Server dürfen
# nicht produktiv genutzt werden und blocken solche Zugriffe). URL im Leaflet-Schema mit
# {s} (Subdomain, optional), {z}/{x}/{y}. Beispiel MapTiler:
#   MAP_TILE_URL=https://api.maptiler.com/maps/streets/{z}/{x}/{y}.png?key=DEIN_KEY
#   MAP_TILE_ATTRIBUTION=&copy; MapTiler &copy; OpenStreetMap-Mitwirkende
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION=&copy; OpenStreetMap-Mitwirkende
MAP_TILE_MAX_ZOOM=19

# --- HTTPS/Sicherheit (nur Produktion relevant) ---
# Auf 1 setzen, sobald die Anwendung ausschließlich über HTTPS erreichbar ist.
DJANGO_SECURE_SSL=0
